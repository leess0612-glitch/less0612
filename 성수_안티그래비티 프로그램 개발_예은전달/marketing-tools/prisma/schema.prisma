generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model SettlementRecord {
  id              String   @id @default(cuid())
  period          String   // e.g. "2026-03"
  serviceName     String
  serviceType     String   @default("general") // internet | rental | general
  grossRevenue    Float
  commissionRate  Float    // 0.0 ~ 1.0
  commissionAmount Float
  rentalCost      Float    @default(0)
  internetCost    Float    @default(0)
  otherExpenses   Float    @default(0)
  netProfit       Float
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ScriptAnalysis {
  id              String   @id @default(cuid())
  sourceType      String   // blog | script
  sourceContent   String
  result          String
  generatedScript String?
  createdAt       DateTime @default(now())
}

model LandingPageProject {
  id             String   @id @default(cuid())
  sourceUrl      String?
  analysisResult String?
  generatedHtml  String?
  screenshotUrl  String?
  createdAt      DateTime @default(now())
}

model ReelsProject {
  id          String   @id @default(cuid())
  title       String
  script      String
  platform    String   // instagram | tiktok | youtube
  videoUrl    String?
  uploadId    String?
  status      String   @default("draft")
  metrics     String?  // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdAnalysis {
  id             String   @id @default(cuid())
  sourceUrl      String
  platform       String   // youtube | instagram
  title          String?
  transcript     String?
  adStructure    String?  // JSON: {hook, body, cta}
  scriptStyle    String?  // JSON: {tone, pacing, keywords}
  visualStyle    String?  // JSON: {style, colors, mood}
  hooks          String?  // JSON array
  targetAudience String?
  rawAnalysis    String?
  generatedAds   GeneratedAd[]
  createdAt      DateTime @default(now())
}

model GeneratedAd {
  id           String      @id @default(cuid())
  analysisId   String
  analysis     AdAnalysis  @relation(fields: [analysisId], references: [id])
  adType       String      // B_slideshow | C_voiceover
  productName  String
  serviceType  String      // rental | internet
  videoPath    String?     // /generated-videos/...
  script       String?
  caption      String?
  hashtags     String?     // JSON array
  status       String      @default("generated") // generated | approved | uploading | uploaded
  uploads      AdUpload[]
  createdAt    DateTime    @default(now())
}

model AdUpload {
  id            String      @id @default(cuid())
  generatedAdId String
  generatedAd   GeneratedAd @relation(fields: [generatedAdId], references: [id])
  platform      String      // instagram | youtube | tiktok
  status        String      @default("pending") // pending | success | failed
  platformId    String?
  error         String?
  uploadedAt    DateTime?
  createdAt     DateTime    @default(now())
}

model InstagramAd {
  id           String    @id @default(cuid())
  serviceType  String    // rental | internet
  productName  String
  price        String?
  features     String    // JSON array
  adCopy       String?   // JSON { headline, subheadline }
  imageUrl     String?   // local path /generated/...
  imagePrompt  String?
  caption      String?
  hashtags     String?   // JSON array
  status       String    @default("draft") // draft | generated | uploaded
  instagramId  String?
  postedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
